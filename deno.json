{
  "imports": {
    "@fastify/auth": "npm:@fastify/auth@^5.0.4",
    "@fastify/jwt": "npm:@fastify/jwt@^10.1.0",
    "@fastify/postgres": "npm:@fastify/postgres@^6.0.2",
    "@fastify/type-provider-typebox": "npm:@fastify/type-provider-typebox@^6.1.0",
    "@types/node": "npm:@types/node@^25.9.1",
    "fastify": "npm:fastify@^5.8.5",
    "fastify-plugin": "npm:fastify-plugin@^5.1.0",
    "graphql": "npm:graphql@^16.14.0",
    "pg": "npm:pg@^8.21.0",
    "pino-pretty": "npm:pino-pretty@^13.1.3"
  },
  "permissions": {
    "dev": {
      "env": {
        "allow": [
          "DB_CONNECTION_STRING",
          "JWT_PRIVATE",

          "NODE_V8_COVERAGE",
          "NODE_PG_FORCE_NATIVE",
          "V8_COVERAGE",

          "TERM",
          "CI",

          "USER",
          "PGBINARY",
          "PGOPTIONS",
          "PGSSLMODE",
          "PGCLIENT_ENCODING",
          "PGREPLICATION",
          "PGAPPNAME",
          "PGCONNECT_TIMEOUT"
        ]
      },
      "sys": {
        "allow": ["hostname", "networkInterfaces"]
      },
      "net": {
        "allow": ["localhost", "127.0.0.1", "[::1]", "0.0.0.0"]
      }
    }
  }
}
