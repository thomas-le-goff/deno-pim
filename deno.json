{
  "imports": {
    "@fastify/postgres": "npm:@fastify/postgres@^6.0.2",
    "@types/node": "npm:@types/node@^25.9.1",
    "fastify": "npm:fastify@^5.8.5",
    "fastify-plugin": "npm:fastify-plugin@^5.1.0",
    "graphql": "npm:graphql@^16.14.0"
  },
  "permissions": {
    "dev": {
      "env": {
        "allow": [
          "DB_CONNECTION_STRING",

          "NODE_V8_COVERAGE",
          "NODE_PG_FORCE_NATIVE",

          "USER",
          "PGBINARY",
          "PGOPTIONS",
          "PGSSLMODE",
          "PGCLIENT_ENCODING",
          "PGREPLICATION",
          "PGAPPNAME",
          "PGCONNECT_TIMEOUT"
        ]
      },
      "sys": {
        "allow": ["hostname"]
      },
      "net": {
        "allow": ["localhost", "127.0.0.1", "[::1]"]
      }
    }
  }
}
