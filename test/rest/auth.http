// Login with valid credentials
POST http://localhost:3000/v1/auth/login
Content-Type: application/json; charset=utf-8

{"username": "admin", "password": "admin"}

{{
  const { equal, ok } = require('assert');

  test("Authorization succeed with bearer token", () => {
    equal(response.statusCode, 200);
    const body = JSON.parse(response.body);
    ok(body.access_token);
    ok(body.refresh_token);
    $global.auth_header = `Bearer ${body.access_token.token}`;
    $global.refresh_token = body.refresh_token.token;
  });
}}

###

// Login with invalid credentials
POST http://localhost:3000/v1/auth/login
Content-Type: application/json; charset=utf-8
Accept-Language: fr-FR
{"username": "admin", "password": "wrongpassword"}

{{
  const { equal } = require('assert');

  test("Authorization failed with wrong credentials", () => {
    equal(response.statusCode, 400);
  });
}}

###

// Login with missing fields
POST http://localhost:3000/v1/auth/login
Content-Type: application/json; charset=utf-8
{"username": "admin"}

{{
  const { equal } = require('assert');

  test("Authorization failed with missing fields", () => {
    equal(response.statusCode, 400);
  });
}}

###

// Get user profile with valid token
GET http://localhost:3000/v1/me
Content-Type: application/json; charset=utf-8
Authorization: {{$global.auth_header}}

{{
  const { equal } = require('assert');

  test("Get user profile with valid token", () => {
    equal(response.statusCode, 200);
    const body = JSON.parse(response.body);
    equal(body.username, "admin");
  });
}}

###

// Get user profile with invalid token
GET http://localhost:3000/v1/me
Content-Type: application/json; charset=utf-8
Authorization: Bearer invalidtoken

{{
  const { equal } = require('assert');

  test("Get user profile with invalid token", () => {
    equal(response.statusCode, 401);
  });
}}

###

// Get user profile without authorization header
GET http://localhost:3000/v1/me
Content-Type: application/json; charset=utf-8

{{
  const { equal } = require('assert');

  test("Get user profile without authorization header", () => {
    equal(response.statusCode, 401);
  });
}}

###

// Refresh authorization token
POST http://localhost:3000/v1/auth/refresh
Content-Type: application/json; charset=utf-8

{ "refresh_token": "{{$global.refresh_token}}" }


{{
    const { equal, ok } = require('assert');

    test("Refresh user authorization token", () => {
      equal(response.statusCode, 200);
      const body = JSON.parse(response.body);
      ok(body.access_token);
      ok(body.refresh_token);
    })
}}

// Re-use of refresh token must failed
POST http://localhost:3000/v1/auth/refresh
Content-Type: application/json; charset=utf-8

{ "refresh_token": "{{$global.refresh_token}}" }


{{
    const { equal, ok } = require('assert');

    test("Reuse of refresh token must failed", () => {
      equal(response.statusCode, 404);
    })
}}
